              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": {\n    \"product_material_id\": \"PM-00001\",\n    \"micron\": 4.5,\n    \"width\": 1.0,\n    \"weight\": \"58.5kgs\",\n    \"grade\": \"A\"\n  },\n  \"observations\": \"Slitting done\"\n}"
            },
            "url": "{{base_url}}/work-orders/{{work_order_id}}/stages/slitting"
          }
        },
        {
          "name": "Advance Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/work-orders/{{work_order_id}}/advance"
          }
        }
      ]
    },
    {
      "name": "Product Orders",
      "item": [
        {
