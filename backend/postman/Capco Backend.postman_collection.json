            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": {\n    \"input1\": \"60kgs\",\n    \"input2\": \"4.5\",\n    \"input3\": \"M-01\",\n    \"input4\": \"2.4\",\n    \"input5\": \"1.5 Ohms\",\n    \"input6\": \"11/01/2025 08:30\",\n    \"input7\": \"SLITTING\"\n  },\n  \"observations\": \"Metallisation done\"\n}"
